# Netra Configuration

# Discord
DISCORD_TOKEN=your_token_here
DISCORD_CLIENT_ID=your_client_id_here
DISCORD_CLIENT_SECRET=your_client_secret_here

# Bot
BOT_PREFIX=n!
OWNER_IDS=1234567890,0987654321
DEFAULT_GUILD_ID=

# Database
DATABASE_URL=sqlite+aiosqlite:///data/netra.db
# For PostgreSQL:
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/netra

# Logging
LOG_LEVEL=INFO

# Sentry (Optional)
SENTRY_DSN=

# Music
MUSIC_MAX_QUEUE_SIZE=100
MUSIC_DEFAULT_VOLUME=50

# Web Dashboard
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8000
SECRET_KEY=generate_a_strong_secret_key
